---
import { profile } from '../../data/profile';
import { ui } from '../../i18n/es';
import AssetIcon from '../ui/AssetIcon.astro';

const visibleSocialLinks = profile.socialLinks.filter((link) => link.visible);
---

<section class="hero">
  <div class="hero__wordmark" aria-hidden="true">{ui.hero.wordmark}</div>

  <div class="hero__portrait">
    <div class="hero__glow"></div>
    <img class="hero__portrait-image" src="/assets/hero/profile-photo.png" alt="Retrato de Hugo Mendoza" />
  </div>

  <div class="hero__copy">
    <h1 class="hero__title">{ui.hero.title}</h1>
    <p class="hero__tagline">{ui.hero.tagline}</p>
    <p class="hero__description">{ui.hero.description}</p>
    <div class="hero__actions">
      <a class="button button--primary" href="/proyectos">{ui.hero.primaryCta} <AssetIcon src="/assets/icons/arrow-right.svg" size={18} /></a>
      <a class="button button--outline" href={`mailto:${profile.email}`}>{ui.hero.secondaryCta} <AssetIcon src="/assets/icons/mail.svg" size={18} /></a>
    </div>
  </div>

  <aside class="hero__availability" aria-label="Disponibilidad">
    <span class="hero__availability-dot"></span>
    <div class="hero__availability-content">
      <strong class="hero__availability-title">{ui.hero.availabilityTitle}</strong>
      <small class="hero__availability-meta">{ui.hero.availabilityMeta}</small>
    </div>
  </aside>

  <div class="hero__social-links" aria-label="Redes sociales">
    {visibleSocialLinks.map((link) => (
      <a class="hero__social-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
        <AssetIcon src={`/assets/icons/${link.icon}.svg`} size={19} />
      </a>
    ))}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(760px, calc(100vh - 120px));
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-subtle);
    padding: clamp(32px, 5vw, 64px) var(--container-padding) 48px;
  }

  .hero__wordmark {
    position: absolute;
    inset: 34px 6% auto;
    color: var(--color-primary);
    font-size: clamp(4.7rem, 13vw, 11rem);
    font-weight: 850;
    line-height: 0.88;
    opacity: 0.04;
    pointer-events: none;
    text-align: center;
    text-transform: uppercase;
  }

  .hero__portrait {
    position: absolute;
    right: 50%;
    bottom: 0;
    z-index: 1;
    width: min(500px, 47vw);
    transform: translateX(50%);
  }

  .hero__portrait::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    height: 24%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0), #ffffff 74%);
    content: "";
    pointer-events: none;
  }

  .hero__portrait-image {
    position: relative;
    z-index: 1;
    width: 100%;
    filter: saturate(0.94) contrast(1.04) brightness(1.025) hue-rotate(-2deg) drop-shadow(0 22px 44px rgba(17, 24, 39, 0.08));
    mask-image: linear-gradient(180deg, #000 0%, #000 76%, rgba(0, 0, 0, 0.72) 86%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 76%, rgba(0, 0, 0, 0.72) 86%, transparent 100%);
  }

  .hero__glow {
    position: absolute;
    right: -4%;
    bottom: 8%;
    left: -4%;
    height: 56%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(233, 69, 96, 0.2) 0%, rgba(233, 69, 96, 0.1) 42%, rgba(233, 69, 96, 0) 72%);
    filter: blur(38px);
  }

  .hero__copy {
    position: absolute;
    bottom: 118px;
    left: var(--container-padding);
    z-index: 2;
    width: min(420px, 38vw);
  }

  .hero__title {
    margin: 0;
    font-size: clamp(3rem, 5.6vw, 5.2rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: 0;
  }

  .hero__tagline {
    margin: 14px 0 0;
    color: var(--color-secondary);
    font-size: clamp(1.65rem, 3vw, 2.45rem);
    font-weight: 760;
    line-height: 1.22;
  }

  .hero__description {
    max-width: 390px;
    margin: 18px 0 0;
    color: var(--color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .hero__availability {
    position: absolute;
    right: var(--container-padding);
    bottom: 152px;
    z-index: 2;
    display: flex;
    min-width: 214px;
    align-items: start;
    gap: 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.9);
    padding: 20px 22px;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(10px);
  }

  .hero__availability-dot {
    width: 8px;
    height: 8px;
    margin-top: 6px;
    border-radius: 50%;
    background: var(--color-secondary);
  }

  .hero__availability-title,
  .hero__availability-meta {
    display: block;
  }

  .hero__availability-meta {
    margin-top: 8px;
    color: var(--color-text-secondary);
  }

  .hero__social-links {
    position: absolute;
    right: 0;
    bottom: 28px;
    left: 0;
    z-index: 3;
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  .hero__social-link {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 1px solid rgba(229, 231, 235, 0.82);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text-muted);
    box-shadow: 0 8px 24px rgba(17, 24, 39, 0.05);
    opacity: 0.9;
    transition:
      color var(--transition-base),
      transform var(--transition-base),
      border-color var(--transition-base),
      background var(--transition-base),
      box-shadow var(--transition-base);
    backdrop-filter: blur(8px);
  }

  .hero__social-link:hover {
    border-color: rgba(233, 69, 96, 0.35);
    background: #ffffff;
    color: var(--color-secondary);
    opacity: 1;
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .hero {
      display: flex;
      min-height: auto;
      flex-direction: column;
      align-items: center;
      padding: 28px 24px 30px;
    }

    .hero__wordmark {
      inset: 34px 4% auto;
      font-size: clamp(4.2rem, 18vw, 6rem);
      opacity: 0.032;
    }

    .hero__portrait {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      width: min(330px, 80vw);
      margin-top: 62px;
      margin-bottom: -18px;
      transform: none;
    }

    .hero__portrait::after {
      height: 30%;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0), #ffffff 70%);
    }

    .hero__portrait-image {
      mask-image: linear-gradient(180deg, #000 0%, #000 68%, rgba(0, 0, 0, 0.62) 82%, transparent 100%);
      -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 68%, rgba(0, 0, 0, 0.62) 82%, transparent 100%);
    }

    .hero__glow {
      right: -12%;
      bottom: 6%;
      left: -12%;
      height: 52%;
      opacity: 0.82;
    }

    .hero__copy {
      position: relative;
      right: auto;
      bottom: auto;
      left: auto;
      z-index: 3;
      width: min(100%, 420px);
      text-align: center;
    }

    .hero__title {
      font-size: clamp(3rem, 11vw, 4.2rem);
      line-height: 0.98;
    }

    .hero__tagline {
      margin-top: 16px;
      font-size: clamp(1.45rem, 6vw, 2rem);
    }

    .hero__description {
      max-width: 340px;
      margin-top: 20px;
      margin-inline: auto;
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .hero__actions {
      display: grid;
      width: min(100%, 334px);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-content: center;
      margin: 28px auto 0;
      gap: 12px;
    }

    .hero__actions .button {
      min-height: 46px;
      padding: 0 18px;
      font-size: 0.9rem;
      white-space: nowrap;
    }

    .hero__availability {
      display: none;
    }

    .hero__social-links {
      position: relative;
      right: auto;
      bottom: auto;
      left: auto;
      margin-top: 34px;
    }
  }

  @media (max-width: 540px) {
    .hero {
      padding: 26px 22px 28px;
    }

    .hero__title {
      font-size: clamp(2.75rem, 12vw, 3.6rem);
    }

    .hero__actions {
      width: min(100%, 332px);
    }
  }

  @media (max-width: 360px) {
    .hero__actions {
      grid-template-columns: 1fr;
    }

    .hero__actions .button {
      width: 100%;
    }
  }
</style>
