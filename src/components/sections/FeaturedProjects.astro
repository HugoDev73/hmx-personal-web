---
import ProjectCard from '../project/ProjectCard.astro';
import { featuredProjects } from '../../data/projects';
import { ui } from '../../i18n/es';
import AssetIcon from '../ui/AssetIcon.astro';
---

<section class="section--tight featured-projects">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{ui.projects.featuredTitle}</h2>
      <a class="text-link" href="/proyectos">{ui.projects.allProjects} <span class="text-link__icon" aria-hidden="true"><AssetIcon src="/assets/icons/arrow-right.svg" size={18} /></span></a>
    </div>

    <div class="featured-projects__grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>

<style>
  .featured-projects {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .featured-projects__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(22px, 3vw, 32px);
  }

  @media (max-width: 760px) {
    .featured-projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
