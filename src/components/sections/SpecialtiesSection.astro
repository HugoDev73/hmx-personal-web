---
import { specialtyItems } from '../../data/specialties';
import { ui } from '../../i18n/es';
import AssetIcon from '../ui/AssetIcon.astro';

const toSoftColor = (hexColor: string, opacity = 0.14) => {
  const hex = hexColor.replace('#', '');
  const value = Number.parseInt(hex.length === 3 ? hex.split('').map((char) => char + char).join('') : hex, 16);
  const red = (value >> 16) & 255;
  const green = (value >> 8) & 255;
  const blue = value & 255;

  return `rgba(${red}, ${green}, ${blue}, ${opacity})`;
};

const getSpecialtyStyle = (color: string) => [
  `--specialty-color: ${color}`,
  `--specialty-color-soft: ${toSoftColor(color)}`,
].join('; ');

const styledSpecialtyItems = specialtyItems.map((item) => ({
  ...item,
  style: getSpecialtyStyle(item.color),
}));
---

<section class="section--tight specialties">
  <div class="container">
    <h2 class="section-title specialties__title">{ui.specialties.title}</h2>

    <div class="specialties__grid">
      {styledSpecialtyItems.map((item) => (
        <a class="specialties__card interactive-card" href="/proyectos" aria-label={`Ver proyectos de ${item.title}`}>
          <div class="specialties__mark" style={item.style}>
            <AssetIcon src={`/assets/icons/${item.icon}.svg`} size={16} />
          </div>
          <div class="specialties__content">
            <h3 class="specialties__card-title">{item.title}</h3>
            <p class="specialties__description">{item.description}</p>
          </div>
          <span class="icon-link" aria-hidden="true">
            <AssetIcon src="/assets/icons/arrow-right.svg" size={19} />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .specialties__title {
    margin-bottom: clamp(28px, 4vw, 44px);
  }

  .specialties__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 24px);
  }

  .specialties__card {
    display: flex;
    min-height: 258px;
    flex-direction: column;
    align-items: flex-start;
    padding: 24px;
  }

  .specialties__mark {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 12px;
    background: var(--specialty-color-soft);
    color: var(--specialty-color);
  }

  .specialties__content {
    width: 100%;
    margin-top: 20px;
  }

  .specialties__card-title {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .specialties__description {
    max-width: 21ch;
    margin: 12px 0 0;
    color: var(--color-text-secondary);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .specialties__card .icon-link {
    width: 36px;
    height: 36px;
    margin-top: auto;
    align-self: flex-end;
    color: var(--color-primary);
    background: #ffffff;
  }

  @media (max-width: 1100px) {
    .specialties__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .specialties__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .specialties__card {
      min-height: 232px;
      padding: 22px;
    }

    .specialties__description {
      max-width: none;
    }
  }
</style>
