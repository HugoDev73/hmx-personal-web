---
import { specialtyItems } from '../../data/specialties';
import { ui } from '../../i18n/es';
import AssetIcon from '../ui/AssetIcon.astro';
---

<section class="section--tight specialties">
  <div class="container">
    <h2 class="section-title specialties__title">{ui.specialties.title}</h2>

    <div class="specialties__grid">
      {specialtyItems.map((item) => (
        <article class="specialties__card">
          <div class:list={['specialties__mark', `specialties__mark--${item.icon}`]}>
            <AssetIcon src={`/assets/icons/${item.icon}.svg`} size={32} />
          </div>
          <div class="specialties__content">
            <h3 class="specialties__card-title">{item.title}</h3>
            <p class="specialties__description">{item.description}</p>
          </div>
          <a class="icon-link" href="/proyectos" aria-label={`Ver proyectos de ${item.title}`}>
            <AssetIcon src="/assets/icons/arrow-right.svg" size={19} />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .specialties__title {
    margin-bottom: clamp(28px, 4vw, 44px);
  }

  .specialties__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(18px, 2.4vw, 28px);
  }

  .specialties__card {
    display: flex;
    min-height: 292px;
    flex-direction: column;
    align-items: flex-start;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: #ffffff;
    padding: 28px;
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .specialties__card:hover {
    transform: translateY(-3px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }

  .specialties__mark {
    display: grid;
    width: 58px;
    height: 58px;
    place-items: center;
    border-radius: 18px;
    background: var(--color-primary);
    color: #ffffff;
  }

  .specialties__content {
    width: 100%;
    margin-top: 24px;
  }

  .specialties__mark--angular {
    background: linear-gradient(135deg, #e94560 0%, #c2185b 55%, #6c00f5 100%);
  }

  .specialties__mark--android {
    background: #3ddc84;
    color: #111827;
  }

  .specialties__mark--frame {
    background: var(--color-secondary);
  }

  .specialties__mark--astro-mono {
    background: var(--color-primary);
  }

  .specialties__card-title {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .specialties__description {
    max-width: 24ch;
    margin: 12px 0 0;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .specialties__card .icon-link {
    width: 42px;
    height: 42px;
    margin-top: auto;
    align-self: flex-end;
    color: var(--color-primary);
  }

  .specialties__card:hover .icon-link {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  @media (max-width: 1100px) {
    .specialties__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .specialties__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .specialties__card {
      min-height: 240px;
      padding: 18px;
    }

    .specialties__description {
      max-width: none;
    }
  }
</style>
