---
type BrandIconName = 'github' | 'linkedin' | 'tiktok' | 'facebook' | 'angular' | 'android' | 'astro' | 'frame';

type Props = {
  name: BrandIconName;
  label?: string;
  size?: number;
  decorative?: boolean;
};

const { name, label, size = 20, decorative = true } = Astro.props;
const accessibleLabel = label ?? name;
