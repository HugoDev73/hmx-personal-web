  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={!decorative ? accessibleLabel : undefined}
