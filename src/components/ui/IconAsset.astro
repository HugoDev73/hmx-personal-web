---
type IconAssetName =
  | 'linkedin'
  | 'github'
  | 'tiktok'
  | 'facebook'
  | 'mail'
  | 'external-link'
  | 'arrow-right'
  | 'arrow-up-right'
  | 'angular'
  | 'android'
  | 'astro'
  | 'frame';

type Props = {
  name: IconAssetName;
  label?: string;
  size?: number;
  decorative?: boolean;
};

const { name, label, size = 20, decorative = true } = Astro.props;
const accessibleLabel = label ?? name;
const viewBoxByName: Record<IconAssetName, string> = {
  linkedin: '0 0 640 640',
  github: '0 0 24 24',
  tiktok: '0 0 24 24',
  facebook: '0 0 24 24',
  mail: '0 0 24 24',
  'external-link': '0 0 24 24',
  'arrow-right': '0 0 24 24',
  'arrow-up-right': '0 0 24 24',
  angular: '0 0 24 24',
  android: '0 0 24 24',
  astro: '0 0 24 24',
  frame: '0 0 24 24',
};
const outlineIcons: IconAssetName[] = ['mail', 'external-link', 'arrow-right', 'arrow-up-right'];
const isOutlineIcon = outlineIcons.includes(name);
---

<svg
  class="asset-icon"
  width={size}
  height={size}
  viewBox={viewBoxByName[name]}
  fill={isOutlineIcon ? 'none' : 'currentColor'}
  stroke={isOutlineIcon ? 'currentColor' : undefined}
  stroke-width={isOutlineIcon ? '2' : undefined}
  stroke-linecap={isOutlineIcon ? 'round' : undefined}
  stroke-linejoin={isOutlineIcon ? 'round' : undefined}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={!decorative ? accessibleLabel : undefined}
  role={!decorative ? 'img' : undefined}
>
  {name === 'linkedin' && (
    <path d="M196.3 512H103.4V212.9h92.9V512ZM149.8 172.1C120.1 172.1 96 147.5 96 117.8c0-14.3 5.7-27.9 15.8-38 10.1-10.1 23.8-15.8 38-15.8 14.2 0 27.9 5.7 38 15.8 10.1 10.1 15.8 23.8 15.8 38 0 29.7-24.1 54.3-53.8 54.3ZM543.9 512h-92.7V366.4c0-34.7-.7-79.2-48.3-79.2-48.3 0-55.7 37.7-55.7 76.7V512h-92.8V212.9h89.1v40.8h1.3c12.4-23.5 42.7-48.3 87.9-48.3 94 0 111.3 61.9 111.3 142.3V512h-.1Z" />
  )}
